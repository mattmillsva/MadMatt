<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.madmatt" name="madmatt's Repo" version="1.0.0" provider-name="Matt Mills">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.addon.repository" name="MadMatt's Repo">
        <dir minversion="19.0.0">
            <info compressed="false">https://mattmillsva.github.io/madmatt/zips/addons.xml</info>
            <checksum>https://mattmillsva.github.io/madmatt/zips/addons.xml.md5</checksum>
            <datadir compressed="true">https://mattmillsva.github.io/madmatt/zips/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Repository for Matt's Kodi Add-ons</summary>
        <description>Installs and updates custom add-ons created by Matt Mills.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>