<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
    <!-- 1. Repository Metadata Block -->
    <addon id="repository.madmatt" name="madmatt's Repo" version="1.0.0" provider-name="Matt Mills">
        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
        </requires>
        <extension point="xbmc.addon.repository" name="madmatt's Repo">
            <dir minversion="19.0.0">
                <info compressed="false">https://mattmillsva.github.io/madmatt/zips/addons.xml</info>
                <checksum>https://mattmillsva.github.io/madmatt/zips/addons.xml.md5</checksum>
                <datadir compressed="true">https://mattmillsva.github.io/madmatt/zips/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary>Repository for madmatt's Kodi Add-ons</summary>
            <description>Installs and updates custom add-ons created by Matt Mills.</description>
            <platform>all</platform>
            <assets>
                <icon>icon.png</icon>
            </assets>
        </extension>
    </addon>

    <!-- 2. Trivia Game Metadata Block -->
    <addon id="script.trivia.game" name="Trivia Game - Movies" version="1.0.48" provider-name="Matt Mills">
        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
        </requires>
        <extension point="xbmc.python.script" library="default.py">
            <provides>executable</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <platform>all</platform>
            <summary lang="en">Multiplayer and AI Movie Trivia Game with Dynamic Profiles</summary>
            <description>Test your cinema knowledge with live questions fetched from OpenTDB! Featuring support for up to 4 players, custom user profiles to track your progress, and a local top 10 leaderboard to compete with friends.</description>
            <license>GPL-3.0-or-later</license>
            <source>https://github.com/mattmillsva/madmatt</source>
            <author>Matt Mills</author>
            <assets>
                <icon>icon.png</icon>
                <fanart>resources/media/fanart.jpg</fanart>
                <screenshot>resources/media/screenshots/screenshot1.jpg</screenshot>
                <screenshot>resources/media/screenshots/screenshot2.jpg</screenshot>
                <screenshot>resources/media/screenshots/screenshot3.jpg</screenshot>
            </assets>
        </extension>
    </addon>
</addons>